# hort-worker environment file (native flavor).
# Written to {{ hort_systemd_env_dir }}/hort-worker.env (mode 0600, owner {{ hort_user }}).
#
# Non-secret values come from group_vars/all.yml.
# SECRET values (marked below) MUST be set in the gitignored
# group_vars/production/ Vault tree — never committed.

# ── Database DSN (runtime DML role) ──────────────────────────────────────────
# HORT_DATABASE_URL is the canonical var for hort-worker (compose confirms this).
# SECRET: set hort_db_runtime_password in group_vars/production/vault.yml
HORT_DATABASE_URL=postgres://{{ postgres_apt_runtime_role }}:{{ hort_db_runtime_password }}@/{{ postgres_apt_db_name }}?host=/var/run/postgresql

# ── Storage backend ───────────────────────────────────────────────────────────
HORT_STORAGE_BACKEND=filesystem
HORT_STORAGE_FILESYSTEM_PATH={{ hort_systemd_cas_dir }}

# ── Scanner CLI binary paths ──────────────────────────────────────────────────
HORT_SCANNER_TRIVY_BIN={{ hort_systemd_trivy_bin }}
HORT_SCANNER_OSV_BIN={{ hort_systemd_osv_bin }}

# ── OSV advisory API ──────────────────────────────────────────────────────────
HORT_ADVISORY_OSV_API_URL=https://api.osv.dev/v1/querybatch

# ── Worker tunables ───────────────────────────────────────────────────────────
HORT_SCANNER_POLL_INTERVAL_SECS=10
HORT_SCANNER_BATCH_SIZE=4
HORT_SCANNER_MAX_ATTEMPTS=5
HORT_SCANNER_LOCK_DURATION_SECS=900
HORT_WORKER_ID=hort-worker-native

# ── Logging ───────────────────────────────────────────────────────────────────
HORT_LOG_FORMAT=json
RUST_LOG=hort_worker=info,hort_app=info,hort_adapters_postgres=info,hort_adapters_scanner_trivy=info,hort_adapters_scanner_osv=info,hort_adapters_advisory_osv=info

# ── Optional: internal CA bundle ─────────────────────────────────────────────
# HORT_EXTRA_CA_BUNDLE=/etc/ssl/certs/extra/ca.crt
