# hort-migrate environment file.
# Written to {{ hort_systemd_env_dir }}/hort-migrate.env (mode 0640, owner root:hort).
#
# The migrate subcommand reads HORT_DATABASE_URL (canonical), falling back to
# bare DATABASE_URL (ADR 0029).  The DDL/migrate role ({{ postgres_apt_ddl_role }})
# must hold CREATE/ALTER/DROP on the artifact_registry database.
#
# SECRET: set hort_db_ddl_password in group_vars/production/vault.yml

HORT_DATABASE_URL=postgres://{{ postgres_apt_ddl_role }}:{{ hort_db_ddl_password }}@/{{ postgres_apt_db_name }}?host=/var/run/postgresql

HORT_LOG_FORMAT=json
RUST_LOG=hort_server=info,hort_adapters_postgres=info,sqlx=warn
