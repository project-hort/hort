# hort-server environment file (native flavor).
# Written to {{ hort_systemd_env_dir }}/hort-server.env (mode 0640, owner root:hort).
#
# Non-secret values come from group_vars/all.yml.
# SECRET values (marked below) MUST be set in the gitignored
# group_vars/production/ Vault tree — never committed.

# ── Database DSN (runtime DML role — used by hort-server serve path) ─────────
# HORT_DATABASE_URL is canonical (ADR 0029); bare DATABASE_URL is the fallback.
# The runtime role ({{ postgres_apt_runtime_role }}) holds DML only (no DDL).
# SECRET: set hort_db_runtime_password in group_vars/production/vault.yml
HORT_DATABASE_URL=postgres://{{ postgres_apt_runtime_role }}:{{ hort_db_runtime_password }}@/{{ postgres_apt_db_name }}?host=/var/run/postgresql

# ── Storage backend ───────────────────────────────────────────────────────────
HORT_STORAGE_BACKEND=filesystem
HORT_STORAGE_FILESYSTEM_PATH={{ hort_systemd_cas_dir }}

# ── Network binds ─────────────────────────────────────────────────────────────
HORT_API_BIND=127.0.0.1:{{ hort_api_port }}
HORT_METRICS_BIND=127.0.0.1:{{ hort_metrics_port }}

# ── Public base URL (nginx terminates TLS) ────────────────────────────────────
HORT_PUBLIC_BASE_URL=https://{{ registry_fqdn }}

# ── Authentication ───────────────────────────────────────────────────────────
# No interactive OIDC / Keycloak in this deployment.  Auth surfaces:
#   - Maintainer PATs (hort_svc_* Bearer tokens) via native-token path
#   - CI OIDC federation (GitHub/GitLab) via gitops OidcIssuer resources
#     → REQUIRES HORT_AUTH_PROVIDER=oidc + HORT_TOKEN_EXCHANGE_ENABLED=true
#       + a valid HORT_OIDC_ISSUER_URL; set these in group_vars/production/
#       when activating the CI exchange path.
#   - OCI /v2 token path (hort_oci_* JWTs signed by HORT_OCI_TOKEN_SIGNING_KEY)
# Disabled mode + native tokens is the correct base for PAT + OCI-token auth.
# CI OIDC federation activation is an intentional operator step (see README).
HORT_AUTH_PROVIDER=disabled
HORT_NATIVE_TOKENS_ENABLED=true

# ── Gitops config directory ───────────────────────────────────────────────────
HORT_CONFIG_DIR={{ hort_config_dir }}

# ── Logging ───────────────────────────────────────────────────────────────────
HORT_LOG_FORMAT=json
RUST_LOG=hort_server=info,hort_app=info,hort_http_core=info,hort_adapters_postgres=info,hort_adapters_oidc=info

# ── Upstream resolver refresh (production default: 60s) ───────────────────────
HORT_UPSTREAM_RESOLVER_REFRESH_SECS=60

# ── Optional: internal CA bundle ─────────────────────────────────────────────
# Uncomment and set in group_vars/production/ if using an internal CA.
# HORT_EXTRA_CA_BUNDLE=/etc/ssl/certs/extra/ca.crt
