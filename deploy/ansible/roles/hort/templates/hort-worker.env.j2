# hort-worker environment file.
# Written to {{ hort_env_dir }}/hort-worker.env (mode 0640, owner root:hort).
#
# Non-secret values come from group_vars/all.yml.
# SECRET values (marked below) MUST be set in the gitignored
# group_vars/production/ Vault tree — never committed.

# ── Database DSN (worker uses HORT_DATABASE_URL, not DATABASE_URL) ────────────
# The worker reads HORT_DATABASE_URL (see deploy/compose/docker-compose.yml).
# SECRET: set hort_db_password in group_vars/production/vault.yml
HORT_DATABASE_URL=postgres://hort:{{ hort_db_password }}@postgres:5432/artifact_registry

# ── Storage backend ───────────────────────────────────────────────────────────
HORT_STORAGE_BACKEND=filesystem
HORT_STORAGE_FILESYSTEM_PATH={{ hort_cas_container_path }}

# ── Scanner CLI binary paths (baked into the worker image) ───────────────────
HORT_SCANNER_TRIVY_BIN=/usr/local/bin/trivy
HORT_SCANNER_OSV_BIN=/usr/local/bin/osv-scanner

# ── OSV advisory API ──────────────────────────────────────────────────────────
HORT_ADVISORY_OSV_API_URL=https://api.osv.dev/v1/querybatch

# ── Worker tunables ───────────────────────────────────────────────────────────
HORT_SCANNER_POLL_INTERVAL_SECS=10
HORT_SCANNER_BATCH_SIZE=4
HORT_SCANNER_MAX_ATTEMPTS=5
HORT_SCANNER_LOCK_DURATION_SECS=900
HORT_WORKER_ID=hort-worker-podman

# ── Logging ───────────────────────────────────────────────────────────────────
HORT_LOG_FORMAT=json
RUST_LOG=hort_worker=info,hort_app=info,hort_adapters_postgres=info,hort_adapters_scanner_trivy=info,hort_adapters_scanner_osv=info,hort_adapters_advisory_osv=info

# ── Optional: internal CA bundle ─────────────────────────────────────────────
# HORT_EXTRA_CA_BUNDLE=/etc/ssl/certs/extra/ca.crt
