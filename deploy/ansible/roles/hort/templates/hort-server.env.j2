# hort-server environment file.
# Written to {{ hort_env_dir }}/hort-server.env (mode 0640, owner root:hort).
#
# Non-secret values come from group_vars/all.yml.
# SECRET values (marked below) MUST be set in the gitignored
# group_vars/production/ Vault tree — never committed.
#
# Also shared with the postgres container (POSTGRES_* vars) and hort-migrate
# (DATABASE_URL) since all three use the same EnvironmentFile= path.

# ── PostgreSQL (also consumed by the postgres.container unit) ─────────────────
POSTGRES_USER=hort
POSTGRES_DB=artifact_registry
# SECRET: set hort_db_password in group_vars/production/vault.yml
POSTGRES_PASSWORD={{ hort_db_password }}

# ── Database DSN (DDL user — used by hort-migrate and hort-server) ────────────
DATABASE_URL=postgres://hort:{{ hort_db_password }}@postgres:5432/artifact_registry

# ── Storage backend ───────────────────────────────────────────────────────────
HORT_STORAGE_BACKEND=filesystem
HORT_STORAGE_FILESYSTEM_PATH={{ hort_cas_container_path }}

# ── Network binds ─────────────────────────────────────────────────────────────
HORT_API_BIND=0.0.0.0:{{ hort_api_port }}
HORT_METRICS_BIND=0.0.0.0:{{ hort_metrics_port }}
# Do NOT set HORT_METRICS_PUBLIC_BIND=true in production — metrics are only
# reachable from within the container network (no published port for 9090).

# ── Public base URL (nginx terminates TLS) ────────────────────────────────────
HORT_PUBLIC_BASE_URL=https://{{ registry_fqdn }}

# ── Authentication ───────────────────────────────────────────────────────────
# No interactive OIDC / Keycloak in this deployment.  Auth surfaces:
#   - Maintainer PATs (hort_svc_* Bearer tokens) via native-token path
#   - CI OIDC federation (GitHub/GitLab CI JWT → gitops OidcIssuer +
#     ServiceAccount rows). Since the federated /exchange decoupling
#     (0.9.4-beta.2+) this needs ONLY HORT_TOKEN_EXCHANGE_ENABLED=true under
#     HORT_AUTH_PROVIDER=disabled — NO interactive identity provider
#     (HORT_OIDC_ISSUER_URL / Keycloak). Each issuer's JWKS is fetched over
#     verified TLS; only the configured aud + claim bindings can exchange.
#   - OCI /v2 token path (hort_oci_* JWTs signed by HORT_OCI_TOKEN_SIGNING_KEY)
HORT_AUTH_PROVIDER=disabled
HORT_NATIVE_TOKENS_ENABLED=true
# CI OIDC federation ON — enables POST /api/v1/auth/exchange. This deploy's
# purpose is dogfood CI federation; the endpoint is inert without a valid
# federated JWT matching a gitops OidcIssuer + ServiceAccount claim binding.
HORT_TOKEN_EXCHANGE_ENABLED=true
# OCI /v2 bearer-token signing key (Ed25519 PKCS#8 PEM) — generated on the host
# by the hort role and bind-mounted read-only into this container. REQUIRED
# because HORT_NATIVE_TOKENS_ENABLED=true (hort-server won't boot without it).
HORT_OCI_TOKEN_SIGNING_KEY_FILE={{ hort_oci_signing_key_container_path }}

# ── Gitops config directory ───────────────────────────────────────────────────
HORT_CONFIG_DIR=/etc/hort/config

# ── Logging ───────────────────────────────────────────────────────────────────
HORT_LOG_FORMAT=json
RUST_LOG=hort_server=info,hort_app=info,hort_http_core=info,hort_adapters_postgres=info,hort_adapters_oidc=info

# ── Upstream resolver refresh (production default: 60s) ───────────────────────
HORT_UPSTREAM_RESOLVER_REFRESH_SECS=60

# ── Optional: internal CA bundle ─────────────────────────────────────────────
# Uncomment and set in group_vars/production/ if using an internal CA.
# HORT_EXTRA_CA_BUNDLE=/etc/ssl/certs/extra/ca.crt
