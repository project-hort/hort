# /etc/nginx/conf.d/ssl-hardening.conf — managed by Ansible (nginx role).
# Pins the TLS policy to the Mozilla intermediate profile.
# Loaded from conf.d/ (http context) so it applies globally once TLS is up.
#
# ssl_prefer_server_ciphers off — let the client pick from the allowed set;
#   modern TLSv1.3 clients always negotiate TLSv1.3 regardless.
#
# This file supplements (does not replace) certbot's options-ssl-nginx.conf
# include in the vhost — nginx merges directives, and more-specific context
# (server/location) overrides http-level defaults.  The certbot include is
# gated on cert presence ({% if nginx_cert_exists %}), so there is no conflict
# in the pre-cert state: this conf.d file sets the policy at http level and
# the certbot include refines it at server level once certs exist.
#
# Cipher list: Mozilla intermediate (2024-06) —
#   https://wiki.mozilla.org/Security/Server_Side_TLS#Intermediate_compatibility

server_tokens off;

ssl_protocols {{ nginx_ssl_protocols }};
ssl_prefer_server_ciphers off;
# Mozilla intermediate cipher list — security-policy constant, do not shorten.
ssl_ciphers ECDHE-ECDSA-AES128-GCM-SHA256:ECDHE-RSA-AES128-GCM-SHA256:ECDHE-ECDSA-AES256-GCM-SHA384:ECDHE-RSA-AES256-GCM-SHA384:ECDHE-ECDSA-CHACHA20-POLY1305:ECDHE-RSA-CHACHA20-POLY1305:DHE-RSA-AES128-GCM-SHA256:DHE-RSA-AES256-GCM-SHA384:DHE-RSA-CHACHA20-POLY1305;
