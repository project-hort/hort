# /etc/nginx/conf.d/ssl-hardening.conf — managed by Ansible (nginx role).
# Sets server_tokens off and http-level TLS baseline (Mozilla intermediate).
#
# server_tokens off — suppress nginx version from error pages and Server header.
#   This directive is http-context only and must live here.
#
# TLS policy (ssl_protocols, ssl_ciphers, ssl_prefer_server_ciphers):
#   These are set here as an http-level baseline that covers the two
#   default_server blocks (port 80 and 443).  The cert-present named vhost
#   block in registry.hort.rs.conf.j2 sets the same directives at server level,
#   which is the authoritative (winning) context for real client connections.
#   The two definitions share the same source: nginx_ssl_protocols and
#   nginx_ssl_ciphers in group_vars/all.yml.
#
# ssl_prefer_server_ciphers off — let the client pick from the allowed set;
#   modern TLSv1.3 clients always negotiate TLSv1.3 regardless.
#
# Cipher list: Mozilla intermediate (2024-06) — single source in
#   nginx_ssl_ciphers (group_vars/all.yml); do not inline a literal here.
#   https://wiki.mozilla.org/Security/Server_Side_TLS#Intermediate_compatibility

server_tokens off;

ssl_protocols {{ nginx_ssl_protocols }};
ssl_prefer_server_ciphers off;
# Mozilla intermediate cipher list — value sourced from nginx_ssl_ciphers var.
ssl_ciphers {{ nginx_ssl_ciphers }};
