# Example local overrides for the dev/CI compose stack
# (deploy/compose/docker-compose.yml). These override the intentionally-weak
# dev defaults baked into the compose file.
#
# Usage: copy to `.env` in this directory (auto-loaded by `docker compose`,
# gitignored), or pass `--env-file <file>`:
#   cp deploy/compose/.env.local.example deploy/compose/.env
# Both `.env` and `.env.local` are gitignored.
#
# Leaving these at the defaults reproduces the committed dev behavior; set
# real values for any non-throwaway deployment (and note: production should
# not use this compose file at all — see the DANGER banner in it).

# PostgreSQL password (compose default: registry). Used by the postgres
# service and every hort DSN
# (`postgres://registry:${POSTGRES_PASSWORD}@postgres:5432/...`).
POSTGRES_PASSWORD=registry

# Keycloak bootstrap-admin password (compose default: admin).
KC_ADMIN_PASSWORD=admin
