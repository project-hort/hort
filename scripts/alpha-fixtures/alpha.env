# Source this in every terminal that runs hort-server or hort-worker.
#   source scripts/alpha-fixtures/alpha.env
#
# Env-var names verified against the actual config readers in
# `crates/hort-server/src/config.rs` and `crates/hort-worker/src/config.rs`.
# `HORT_DATABASE_URL` is the canonical DSN var for BOTH binaries, with bare
# `DATABASE_URL` as a compat fallback.

# --- Database ---------------------------------------------------------
# Both hort-server and hort-worker read `HORT_DATABASE_URL` first, falling
# back to bare `DATABASE_URL` (sqlx-cli / Tier-2 / 12-factor). Set both so a
# single source covers the canonical name AND the fallback / tooling readers.
export DATABASE_URL="postgresql://registry:registry@localhost:30432/artifact_registry"
export HORT_DATABASE_URL="$DATABASE_URL"

# --- Ephemeral keyspace ----------------------------------------------
# hort-server reads `HORT_REDIS_URL` (PAT cache, PAT-lockout counter).
# hort-worker reads `HORT_REDIS_URL_EVICTABLE` (prefetch dedup).
# Both point at the same redis for the alpha (separate databases on
# the same instance keep the keyspaces isolated).
export HORT_REDIS_URL="redis://localhost:30379/0"
export HORT_REDIS_URL_EVICTABLE="redis://localhost:30379/1"

# --- Storage ----------------------------------------------------------
# Filesystem CAS. S3 / minio is out of scope for alpha.
export HORT_STORAGE_BACKEND=filesystem
export HORT_STORAGE_FILESYSTEM_PATH="${HORT_STORAGE_FILESYSTEM_PATH:-$(pwd)/data/alpha/storage}"

# --- Network ----------------------------------------------------------
export HORT_API_BIND="127.0.0.1:8080"
export HORT_PUBLIC_BASE_URL="http://localhost:8080"

# --- Gitops config ----------------------------------------------------
# Track A (no OIDC) points at the `base/` overlay — repositories,
# upstreams, and policies only. The OIDC `auth/` ClaimMappings live one
# level up under gitops-config/ and are applied ONLY by Track B (which
# overrides HORT_CONFIG_DIR in alpha.env.oidc); hort-server fail-closes
# at boot if ClaimMappings are declared while HORT_AUTH_PROVIDER=disabled.
export HORT_CONFIG_DIR="${HORT_CONFIG_DIR:-$(pwd)/scripts/alpha-fixtures/gitops-config/base}"

# --- Native-token auth (the PAT-only scope this runbook uses) ---------
# hort-server refuses to start without either an OIDC provider or
# native tokens enabled. The alpha runbook is PAT-only, so:
export HORT_NATIVE_TOKENS_ENABLED=true
# Local alpha is HTTP (not HTTPS). By default hort-server refuses
# bearer-token writes over plain HTTP — this knob enables them for
# local dev. Production deployments MUST set this to false (default).
export HORT_BEARER_ALLOW_OVER_HTTP=true
# Native tokens require an Ed25519 signing key.
# Generate once with:
#   openssl genpkey -algorithm Ed25519 -out ./data/alpha/oci-signing-key.pem
#   chmod 600 ./data/alpha/oci-signing-key.pem
# The setup script (setup-alpha-env.sh) should mint this, but until
# that lands, the alpha tester runs the openssl line above and the
# env var below picks it up.
export HORT_OCI_TOKEN_SIGNING_KEY_FILE="${HORT_OCI_TOKEN_SIGNING_KEY_FILE:-$(pwd)/data/alpha/oci-signing-key.pem}"

# --- Admin auth gate -------------------------------------------------
export HORT_TOKEN_ALLOW_ADMIN=true

# --- Metrics ----------------------------------------------------------
# Local alpha scrapes /metrics anonymously (the runbook's readiness and
# §9 prefetch assertions curl it without a bearer). hort-server requires
# auth on /metrics by default; disable that for local dev only. Mirrors
# deploy/compose/docker-compose.yml. Production MUST leave this unset (true).
export HORT_METRICS_REQUIRE_AUTH=false

# --- Scanners (hort-worker) ------------------------------------------
export HORT_SCANNER_TRIVY_BIN="${HORT_SCANNER_TRIVY_BIN:-trivy}"
export HORT_SCANNER_OSV_BIN="${HORT_SCANNER_OSV_BIN:-osv-scanner}"

# --- Worker tuning (concurrency backstop) ----------------------------
export HORT_WORKER_LOCK_TIMEOUT_MS=120000

# --- Logging ----------------------------------------------------------
export RUST_LOG="info,hort_=debug,sqlx=warn,hyper=info,reqwest=warn"
