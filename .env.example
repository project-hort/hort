# =============================================================================
# Hort — example environment configuration
# =============================================================================
# Copy to `.env` and adjust. These are the variables the `hort-server` binary
# reads (the `migrate` and `serve` subcommands). This is a starter set — the
# authoritative, exhaustive list lives in:
#   - docs/architecture/how-to/deploy/values-reference.md
#   - deploy/helm/hort-server/values.schema.json  (the Helm knobs)
#   - deploy/compose/docker-compose.yml           (a working stack)

# --- Database (required) -----------------------------------------------------
# Postgres DSN. hort-server reads DATABASE_URL. (hort-worker reads
# HORT_DATABASE_URL, falling back to DATABASE_URL.) Apply the schema with
# `hort-server migrate` before `serve`; the serve runtime never runs DDL.
DATABASE_URL=postgresql://hort:hort@localhost:5432/hort

# --- Storage (required) ------------------------------------------------------
# Content-addressed storage backend: "filesystem" (default) or "s3".
HORT_STORAGE_BACKEND=filesystem
# filesystem backend — directory for the CAS blobs:
HORT_STORAGE_FILESYSTEM_PATH=/var/lib/hort-server/cas
# s3 backend (when HORT_STORAGE_BACKEND=s3) also needs:
#   AWS_ACCESS_KEY_ID=...
#   AWS_SECRET_ACCESS_KEY=...

# --- Bind addresses + public URL ---------------------------------------------
HORT_API_BIND=0.0.0.0:8080
HORT_METRICS_BIND=0.0.0.0:9090
# Base URL advertised to clients (index URLs, OCI Location headers, …):
HORT_PUBLIC_BASE_URL=http://localhost:8080

# --- Authentication ----------------------------------------------------------
# "disabled" (native personal-access tokens only) or "oidc".
HORT_AUTH_PROVIDER=oidc
# OIDC settings (required when HORT_AUTH_PROVIDER=oidc):
HORT_OIDC_ISSUER_URL=https://idp.example.com/realms/hort
HORT_OIDC_AUDIENCE=hort-server
HORT_OIDC_GROUPS_CLAIM=groups
# HORT_OIDC_CLI_CLIENT_ID=hort-cli

# --- GitOps config -----------------------------------------------------------
# Directory of declarative repository / auth / policy YAML applied at boot.
HORT_CONFIG_DIR=/etc/hort/config

# --- Ephemeral store (optional) ----------------------------------------------
# Defaults to in-memory. For a Redis-backed ephemeral store:
#   HORT_EPHEMERAL_STORE_BACKEND=redis
#   HORT_REDIS_URL=redis://localhost:6379

# --- Observability -----------------------------------------------------------
HORT_LOG_FORMAT=json
RUST_LOG=hort_server=info,hort_app=info

# --- Internal TLS (optional) -------------------------------------------------
# Trust an internal CA bundle (the supported mechanism — never an
# *_INSECURE_TLS knob):
# HORT_EXTRA_CA_BUNDLE=/etc/ssl/certs/internal-ca.pem
